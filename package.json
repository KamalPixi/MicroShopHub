{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "build:frontend": "npm run build --prefix store-frontend",
        "build:backend": "vite build",
        "build": "npm run build:frontend && npm run build:backend",
        "dev:frontend": "npm run dev --prefix store-frontend",
        "dev:backend": "vite",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-echo": "^1.15.4",
        "pusher-js": "^8.4.0",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.4"
    }
}
